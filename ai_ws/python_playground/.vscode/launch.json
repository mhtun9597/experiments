{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Module",
            "type": "debugpy",
            "request": "launch",
            "module": "${relativeFileDirname}.${fileBasenameNoExtension}"
        },
        {
            "name": "Python Debugger: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "_fast_api.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8083",
                "--reload",
            ],
            "jinja": true
        },
        {
            "name": "Python Debugger: OTEL FAST API",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "__otel.app.main:app",
                "--host",
                "localhost",
                "--port",
                "8084",
                "--reload",
            ],
            "jinja": true
        }
    ]
}